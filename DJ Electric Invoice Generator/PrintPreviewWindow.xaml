<Window x:Class="DJ_Electric_Invoice_Generator.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Print Preview"
        Height="860"
        Width="980"
        MinHeight="720"
        MinWidth="820"
        WindowStartupLocation="CenterOwner"
        Background="#F5F1E8"
        FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#FFF8F3EA"
                BorderBrush="#FFE7DFD0"
                BorderThickness="1"
                CornerRadius="22"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Print Preview"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#FF1F2530" />
                    <TextBlock Text="Review the invoice before sending it to a printer."
                               Margin="0,6,0,0"
                               Foreground="#FF697483" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="PreviewPrintButton"
                            Content="Print"
                            Click="PreviewPrintButton_Click"
                            Padding="16,10"
                            Margin="0,0,10,0"
                            MinWidth="110"
                            FontWeight="SemiBold"
                            Background="#FF1F2530"
                            Foreground="White"
                            BorderThickness="0" />
                    <Button Content="Close"
                            Click="CloseButton_Click"
                            Padding="16,10"
                            MinWidth="110"
                            FontWeight="SemiBold"
                            Background="#FFF2E4C1"
                            Foreground="#FF1F2530"
                            BorderBrush="#FFCDA86A"
                            BorderThickness="1" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,16,0,0"
                Background="White"
                BorderBrush="#FFE7DFD0"
                BorderThickness="1"
                CornerRadius="24"
                Padding="18">
            <FlowDocumentPageViewer x:Name="PreviewViewer"
                                    Zoom="90" />
        </Border>
    </Grid>
</Window>
