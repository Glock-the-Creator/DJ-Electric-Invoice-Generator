<Window x:Class="DJ_Electric_Invoice_Generator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DJ Electric Invoice Generator"
        Height="900"
        Width="1420"
        MinHeight="760"
        MinWidth="1180"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F5F1E8"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        Icon="Assets/lightbulb.ico">
    <Window.Resources>
        <LinearGradientBrush x:Key="AppBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F7F4EC" Offset="0" />
            <GradientStop Color="#EEF2F7" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="ShellBrush" Color="#FFF8F3EA" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFCF6" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FFDB8A20" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#FF8B5E1A" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#FFF6EACF" />
        <SolidColorBrush x:Key="InkBrush" Color="#FF1F2530" />
        <SolidColorBrush x:Key="MutedBrush" Color="#FF697483" />
        <SolidColorBrush x:Key="LineBrush" Color="#FFE7DFD0" />
        <SolidColorBrush x:Key="PreviewPanelBrush" Color="#FFFCF7EA" />

        <Style x:Key="PanelCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ShellBrush}" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Margin" Value="0,8,0,4" />
        </Style>

        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Background" Value="#FFFFFEFB" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="CurrencyFieldShell" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFEFB" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="CurrencyFieldBox" TargetType="TextBox" BasedOn="{StaticResource FieldBox}">
            <Setter Property="Padding" Value="0,8,10,8" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
        </Style>

        <Style x:Key="CurrencyGlyph" TargetType="TextBlock">
            <Setter Property="Margin" Value="12,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource AccentDarkBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource InkBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AccentDarkBrush}" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <Grid Margin="22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.48*" />
                <ColumnDefinition Width="0.52*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="LeftPanel">
                    <Border Style="{StaticResource PanelCard}" Background="Transparent" Padding="0" Margin="0,0,0,22">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Width="74"
                                    Height="74"
                                    Background="{StaticResource AccentBrush}"
                                    CornerRadius="22">
                                <Viewbox Stretch="Uniform">
                                    <Grid Width="60" Height="60">
                                        <Ellipse Width="60" Height="60" Fill="#22FFFFFF" />
                                        <Path Fill="White"
                                              Stretch="Uniform"
                                              Width="28"
                                              Height="36"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Data="M14,1 C7.2,1 1.7,6.5 1.7,13.3 C1.7,17.2 3.4,20.5 6.4,23.4 C8.5,25.5 9.7,28 9.8,30.9 L18.2,30.9 C18.3,28 19.5,25.5 21.6,23.4 C24.6,20.5 26.3,17.2 26.3,13.3 C26.3,6.5 20.8,1 14,1 Z M8.8,33.5 L19.2,33.5 L19.2,36.4 L8.8,36.4 Z M10.6,38.5 L17.4,38.5 C16.8,40.4 15.6,41.3 14,41.3 C12.4,41.3 11.2,40.4 10.6,38.5 Z" />
                                    </Grid>
                                </Viewbox>
                            </Border>

                            <Grid Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="DJ Electric Invoice Generator"
                                           FontFamily="Segoe UI Semibold"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource PanelCard}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="Invoice" Style="{StaticResource SectionTitle}" />

                            <StackPanel Width="220" HorizontalAlignment="Left">
                                <TextBlock Text="Invoice number" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="InvoiceNumberTextBox"
                                         AutomationProperties.AutomationId="InvoiceNumberTextBox"
                                         Style="{StaticResource FieldBox}"
                                         Text="{Binding InvoiceNumber, UpdateSourceTrigger=PropertyChanged}"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Disabled"
                                         MinHeight="38"
                                         MaxHeight="86"
                                         TextChanged="InvoiceNumberTextBox_TextChanged"
                                         SizeChanged="InvoiceNumberTextBox_SizeChanged" />
                            </StackPanel>

                            <StackPanel Width="220" HorizontalAlignment="Left">
                                <TextBlock Text="Bid amount" Style="{StaticResource FieldLabel}" />
                                <Border Style="{StaticResource CurrencyFieldShell}">
                                    <DockPanel LastChildFill="True">
                                        <TextBlock Text="$" Style="{StaticResource CurrencyGlyph}" />
                                        <TextBox Style="{StaticResource CurrencyFieldBox}"
                                                 Text="{Binding BidNumber, UpdateSourceTrigger=PropertyChanged}" />
                                    </DockPanel>
                                </Border>
                            </StackPanel>

                            <TextBlock Text="Bill to" Style="{StaticResource FieldLabel}" />
                            <TextBox x:Name="BillToTextBox"
                                     Style="{StaticResource FieldBox}"
                                     Text="{Binding BillTo, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Disabled"
                                     MinHeight="38"
                                     MaxHeight="110"
                                     TextChanged="BillToTextBox_TextChanged"
                                     SizeChanged="BillToTextBox_SizeChanged" />

                            <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,14,0,12" />

                            <TextBlock Text="Charges" Style="{StaticResource SectionTitle}" />

                            <Grid Margin="0,10,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="88" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Description"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12" />
                                <TextBlock Grid.Column="1"
                                           Text="Amount"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Charges}" Margin="0,0,0,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FFFFFEFB"
                                                BorderBrush="{StaticResource LineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="16"
                                                Padding="8"
                                                Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="140" />
                                                    <ColumnDefinition Width="88" />
                                                </Grid.ColumnDefinitions>

                                                <TextBox Grid.Column="0"
                                                         AutomationProperties.AutomationId="ChargeDescriptionTextBox"
                                                         Style="{StaticResource FieldBox}"
                                                         Margin="0,0,10,0"
                                                         Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Disabled"
                                                         VerticalContentAlignment="Top"
                                                         MinHeight="38"
                                                         MaxHeight="120"
                                                         TextChanged="ChargeDescriptionTextBox_TextChanged"
                                                         SizeChanged="ChargeDescriptionTextBox_SizeChanged" />

                                                <Border Grid.Column="1"
                                                        Style="{StaticResource CurrencyFieldShell}"
                                                        Margin="0,0,10,0">
                                                    <DockPanel LastChildFill="True">
                                                        <TextBlock Text="$" Style="{StaticResource CurrencyGlyph}" />
                                                        <TextBox Style="{StaticResource CurrencyFieldBox}"
                                                                 Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}" />
                                                    </DockPanel>
                                                </Border>

                                                <Button Grid.Column="2"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Content="Remove"
                                                        Click="RemoveCharge_Click" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Style="{StaticResource SecondaryButton}"
                                    Content="Add charge"
                                    Click="AddCharge_Click"
                                    HorizontalAlignment="Left" />

                            <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,14,0,12" />

                            <TextBlock Text="Totals" Style="{StaticResource SectionTitle}" />

                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="Balance" Style="{StaticResource FieldLabel}" />
                                    <Border Style="{StaticResource CurrencyFieldShell}">
                                        <DockPanel LastChildFill="True">
                                            <TextBlock Text="$" Style="{StaticResource CurrencyGlyph}" />
                                            <TextBox Style="{StaticResource CurrencyFieldBox}"
                                                     Text="{Binding BalanceText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DockPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Addendum amount" Style="{StaticResource FieldLabel}" />
                                    <Border Style="{StaticResource CurrencyFieldShell}">
                                        <DockPanel LastChildFill="True">
                                            <TextBlock Text="$" Style="{StaticResource CurrencyGlyph}" />
                                            <TextBox Style="{StaticResource CurrencyFieldBox}"
                                                     Text="{Binding AddendumAmountText, UpdateSourceTrigger=PropertyChanged}" />
                                        </DockPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Addendum notes" Style="{StaticResource FieldLabel}" />
                            <TextBox Style="{StaticResource FieldBox}"
                                     Text="{Binding AddendumNotes, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="96"
                                     MaxHeight="160"
                                     VerticalScrollBarVisibility="Auto" />

                            <Border Height="1" Background="{StaticResource LineBrush}" Margin="0,14,0,12" />

                            <TextBlock Text="Output" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="Download a local PDF, open a print preview, or check for app updates."
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource MutedBrush}"
                                       TextWrapping="Wrap" />

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,10,0,0">
                                <Button Style="{StaticResource PrimaryButton}"
                                        Content="Download invoice"
                                        Click="DownloadInvoiceButton_Click"
                                        HorizontalAlignment="Left" />
                                <Button Style="{StaticResource SecondaryButton}"
                                        Content="Print invoice"
                                        Click="PrintInvoiceButton_Click"
                                        Margin="10,0,0,0"
                                        HorizontalAlignment="Left" />
                                <Button Style="{StaticResource SecondaryButton}"
                                        Content="Check for updates"
                                        Click="CheckForUpdatesButton_Click"
                                        Margin="10,0,0,0"
                                        HorizontalAlignment="Left" />
                            </StackPanel>

                            <TextBlock Text="{Binding StatusMessage}"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource InkBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding LastSavedDocumentPath}"
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="1"
                          Margin="22,0,0,0"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled">
                <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
                    <Border Width="760"
                            Padding="28"
                            Background="{StaticResource CardBrush}"
                            CornerRadius="28"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1">
                    <StackPanel x:Name="PreviewPanel">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="50"
                                            Height="50"
                                            Background="{StaticResource AccentBrush}"
                                            CornerRadius="16"
                                            Margin="0,0,14,0">
                                        <Viewbox Stretch="Uniform">
                                            <Grid Width="40" Height="40">
                                                <Path Fill="White"
                                                      Stretch="Uniform"
                                                      Width="22"
                                                      Height="30"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M14,1 C7.2,1 1.7,6.5 1.7,13.3 C1.7,17.2 3.4,20.5 6.4,23.4 C8.5,25.5 9.7,28 9.8,30.9 L18.2,30.9 C18.3,28 19.5,25.5 21.6,23.4 C24.6,20.5 26.3,17.2 26.3,13.3 C26.3,6.5 20.8,1 14,1 Z M8.8,33.5 L19.2,33.5 L19.2,36.4 L8.8,36.4 Z M10.6,38.5 L17.4,38.5 C16.8,40.4 15.6,41.3 14,41.3 C12.4,41.3 11.2,40.4 10.6,38.5 Z" />
                                            </Grid>
                                        </Viewbox>
                                    </Border>

                                    <StackPanel>
                                        <TextBlock Text="{Binding CompanyName}"
                                                   FontFamily="Segoe UI Semibold"
                                                   FontSize="28"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource InkBrush}" />
                                        <TextBlock Text="{Binding CompanyTagline}"
                                                   Margin="0,4,0,0"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentDarkBrush}" />
                                        <TextBlock Text="{Binding CompanyAddress}"
                                                   Margin="0,10,0,0"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding CompanyPhone}"
                                                   Foreground="{StaticResource MutedBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        HorizontalAlignment="Right">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            MaxWidth="220">
                                    <TextBlock Text="INVOICE"
                                               FontFamily="Segoe UI Semibold"
                                               FontSize="34"
                                               Foreground="{StaticResource AccentDarkBrush}"
                                               HorizontalAlignment="Right" />
                                    <TextBlock Text="{Binding InvoiceNumber}"
                                               Margin="10,0,0,0"
                                               FontFamily="Segoe UI Semibold"
                                               FontSize="34"
                                               Foreground="{StaticResource AccentDarkBrush}"
                                               TextWrapping="Wrap"
                                               MaxWidth="120"
                                               HorizontalAlignment="Right">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding InvoiceNumber}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Text="DATE"
                                           Margin="0,14,0,2"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedBrush}"
                                           HorizontalAlignment="Right" />
                                <TextBlock Text="{Binding InvoiceDate}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}"
                                           HorizontalAlignment="Right" />
                            </StackPanel>
                        </Grid>

                        <Border Background="{StaticResource PreviewPanelBrush}"
                                CornerRadius="18"
                                Padding="18"
                                Margin="0,24,0,0">
                            <StackPanel>
                                <TextBlock Text="Bill To"
                                           FontFamily="Segoe UI Semibold"
                                           FontSize="14"
                                           Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Text="{Binding BillTo}"
                                           Margin="0,8,0,0"
                                           FontSize="15"
                                           Foreground="{StaticResource InkBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,24,0,0"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="22"
                                Background="White">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="44" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="160" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.ColumnSpan="2"
                                        Background="{StaticResource PreviewPanelBrush}"
                                        CornerRadius="22,22,0,0" />

                                <TextBlock Text="DESCRIPTION"
                                           Margin="18,0,0,0"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Semibold"
                                           FontSize="13"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="AMOUNT"
                                           Margin="0,0,18,0"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           FontFamily="Segoe UI Semibold"
                                           FontSize="13"
                                           Foreground="{StaticResource InkBrush}" />

                                <Border Grid.Row="1"
                                        Grid.Column="1"
                                        Width="1"
                                        Background="{StaticResource LineBrush}"
                                        HorizontalAlignment="Left" />

                                <ItemsControl Grid.Row="1"
                                              Grid.ColumnSpan="2"
                                              Margin="18,16,18,116"
                                              ItemsSource="{Binding Charges}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="160" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Description}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource InkBrush}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding AmountDisplay}"
                                                           HorizontalAlignment="Right"
                                                           Foreground="{StaticResource InkBrush}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Grid Grid.Row="1"
                                      Grid.ColumnSpan="2"
                                      VerticalAlignment="Bottom"
                                      Margin="0,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="32" />
                                        <RowDefinition Height="32" />
                                        <RowDefinition Height="32" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="Bid"
                                               Grid.Row="0"
                                               Margin="0,0,14,0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}" />
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               Text="{Binding BidDisplay}"
                                               Margin="0,0,18,0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Foreground="{StaticResource InkBrush}" />

                                    <Border Grid.Row="1"
                                            Grid.ColumnSpan="2"
                                            Height="1"
                                            Background="{StaticResource LineBrush}"
                                            VerticalAlignment="Top" />
                                    <TextBlock Text="Balance"
                                               Grid.Row="1"
                                               Margin="0,0,14,0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="1"
                                               Text="{Binding BalanceDisplay}"
                                               Margin="0,0,18,0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Foreground="{StaticResource InkBrush}" />

                                    <Border Grid.Row="2"
                                            Grid.ColumnSpan="2"
                                            Height="1"
                                            Background="{StaticResource LineBrush}"
                                            VerticalAlignment="Top" />
                                    <TextBlock Text="Addendums"
                                               Grid.Row="2"
                                               Margin="0,0,14,0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="1"
                                               Text="{Binding AddendumAmountDisplay}"
                                               Margin="0,0,18,0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Foreground="{StaticResource InkBrush}" />
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Margin="0,12,0,0"
                                Background="White"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Charges total"
                                           Foreground="{StaticResource MutedBrush}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ChargesTotalDisplay}"
                                           Foreground="{StaticResource InkBrush}" />
                            </Grid>
                        </Border>

                        <Border Margin="0,10,0,0"
                                Background="{StaticResource InkBrush}"
                                CornerRadius="16"
                                Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="TOTAL"
                                           FontFamily="Segoe UI Semibold"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="White" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TotalDisplay}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="White" />
                            </Grid>
                        </Border>

                        <Border Margin="0,20,0,0"
                                Padding="18,18,18,0"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="0,1,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding PaymentNote}"
                                           Foreground="{StaticResource InkBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ContactLabel}"
                                           Margin="0,10,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ContactPhone}"
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource InkBrush}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
                </Viewbox>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
